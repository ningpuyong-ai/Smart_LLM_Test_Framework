# ===== 1. 测试平台切换为 Dify =====
API_PLATFORM=dify

# ===== 2. Dify 代理/被测目标配置 =====
LLM_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=http://localhost/v1

# ===== 3. LLMJudge 智能裁判模型配置 =====
JUDGE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
JUDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
JUDGE_MODEL=qwen-plus

# ===== 4. 全局超时时间 =====
REQUEST_TIMEOUT=60